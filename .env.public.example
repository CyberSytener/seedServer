# Public runtime mode (required for hardened behavior in app settings)
PUBLIC_MODE=1
SEED_ENV=production
SEED_LOG_LEVEL=INFO
SEED_METRICS_ENABLED=1
SEED_MAX_REQUEST_BODY_BYTES=10485760

# Auth and security (must be changed before going public)
SEED_ADMIN_KEY=change_me_to_a_long_random_value
SEED_API_KEY_PEPPER=change_me_to_a_long_random_value
SEED_TEST_AUTH_MODE=0
SEED_ENABLE_LEGACY_X_USER_ID=0
SEED_SEED_DEV_USERS_ON_STARTUP=0

# Strict public CORS
SEED_DEV_CORS=0
ALLOWED_ORIGINS=https://neoeats.no,https://www.neoeats.no
SEED_CORS_ORIGINS=https://neoeats.no,https://www.neoeats.no

# Disable test/debug surfaces for public mode
SEED_PROMPT_TEST_MODE=0
SEED_ENABLE_STUB=0

# Local service wiring inside docker-compose.public.yml
SEED_REDIS_URL=redis://redis:6379/0
SEED_REDIS_NAMESPACE=seed
SEED_DB_PATH=/data/seed.db
DATABASE_URL=postgresql://seed:seed@postgres:5432/seed_server
SEED_SAGA_DB_URL=postgresql://seed:seed@postgres:5432/seed_server

# Postgres container credentials
POSTGRES_DB=seed_server
POSTGRES_USER=seed
POSTGRES_PASSWORD=change_me_postgres_password

# Expose API only on localhost (use 8001 to avoid clashing with local dev on 8000)
PUBLIC_BIND_PORT=8001
# Cloudflare/Caddy frontend listener for neoeats.no and www.neoeats.no
FRONTEND_PUBLIC_PORT=8080

# LLM provider keys (set at least one provider key)
OPENAI_API_KEY=
GEMINI_API_KEY=
SEED_DEFAULT_PROVIDER_FAST=gemini
SEED_DEFAULT_PROVIDER_BATCH=gemini
SEED_OPENAI_MODEL_FAST=gpt-4.1-mini
SEED_OPENAI_MODEL_BATCH=gpt-4.1
SEED_GEMINI_MODEL_FAST=gemini-2.0-flash
SEED_GEMINI_MODEL_BATCH=gemini-2.5-pro

# Optional metadata for scripts/docs
CLOUDFLARE_TUNNEL_NAME=seed-public
CLOUDFLARE_TUNNEL_ID=
