# Seed Server environment example
#
# Portfolio demo:
#   You do not need to copy this file. Run:
#     python scripts/run_portfolio_demo.py
#
# Manual local development:
#   cp .env.example .env
#   fill in SEED_ADMIN_KEY and SEED_API_KEY_PEPPER

# Environment
SEED_ENV=development
PUBLIC_MODE=false

# Core storage
SEED_DB_PATH=./seed.db
SEED_DEFAULT_PLAN=free
SEED_EMERGENCY_MODE=false

# Auth
SEED_ADMIN_KEY=
SEED_API_KEY_PEPPER=
SEED_ENABLE_LEGACY_X_USER_ID=false
SEED_JWT_AUDIENCE=seed-server
SEED_JWT_ISSUER=seed-server

# Redis
# The portfolio demo does not require a live Redis server.
SEED_REDIS_URL=redis://localhost:6379/0
SEED_REDIS_NAMESPACE=seed

# Workers
SEED_EMBEDDED_WORKERS=false
SEED_EMBEDDED_SCHEDULER=false
SEED_EMBEDDED_WORKER_QUEUES=q_fast,q_batch,q_low

# Providers
# Use stub for local/demo mode. Switch to gemini/openai only when keys are set.
SEED_ENABLE_STUB=true
SEED_DEFAULT_PROVIDER_FAST=stub
SEED_DEFAULT_PROVIDER_BATCH=stub

OPENAI_API_KEY=
SEED_OPENAI_BASE_URL=https://api.openai.com
SEED_OPENAI_MODEL_FAST=gpt-4.1-mini
SEED_OPENAI_MODEL_BATCH=gpt-4.1
SEED_ENABLE_OPENAI=false

GEMINI_API_KEY=
SEED_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
SEED_GEMINI_MODEL_FAST=gemini-2.0-flash
SEED_GEMINI_MODEL_BATCH=gemini-2.5-pro
SEED_ENABLE_GEMINI=false

# Limits
SEED_HARD_RPM_DEFAULT=240
SEED_HARD_RPS_DEFAULT=20
SEED_FAST_TIMEOUT_SEC=3
SEED_MAX_INPUT_CHARS_DEFAULT=12000
SEED_MAX_OUTPUT_CHARS_DEFAULT=20000
SEED_MAX_REQUEST_BODY_BYTES=10485760

# CORS
SEED_CORS_ORIGINS=
ALLOWED_ORIGINS=
SEED_DEV_CORS=false

# Monitoring
SEED_METRICS_ENABLED=true
SEED_LOG_LEVEL=INFO

# Dev / demo auth
SEED_DEV=true
SEED_OPTIMIZE_MODE=false
SEED_PROMPT_TEST_MODE=false
SEED_PARSER_VERSION=baseline
SEED_SEED_DEV_USERS_ON_STARTUP=false
SEED_DEV_INVENTORY_SEED_ON_LOGIN=false

SEED_TEST_AUTH_MODE=false
SEED_TEST_AUTH_DEFAULT_ROLE=developer
SEED_TEST_AUTH_DEFAULT_SCOPES=runs:read,runs:write,modules:read,flows:read,flows:write,catalog:read,blueprints:write,providers:read

# Agent sandbox
SEED_SANDBOX_ENABLED=false
SEED_AGENT_SESSION_TTL_SECONDS=3600
SEED_AGENT_MAX_NESTING_DEPTH=3
SEED_AGENT_MAX_PARALLEL_CHILDREN=5
SEED_SANDBOX_EGRESS_PROXY_URL=http://sandbox_egress_proxy:3128
SEED_SANDBOX_EGRESS_ALLOWLIST=github.com,api.github.com,raw.githubusercontent.com,codeload.github.com

# Module publication authority
# Keep empty for normal local development. Never commit a real value.
SEED_MODULE_EVIDENCE_SIGNING_KEY=
SEED_MODULE_SANDBOX_IMAGE=seed-module-sandbox:local
