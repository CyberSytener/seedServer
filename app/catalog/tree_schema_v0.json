{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tree_schema_v0.json",
  "title": "Seed Catalog Tree Schema v0",
  "type": "object",
  "required": [
    "catalog_version",
    "title",
    "root",
    "sections",
    "nodes"
  ],
  "properties": {
    "catalog_version": {
      "const": "v0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "root": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_:-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "path_prefix": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "kind",
          "path",
          "tags",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "dsl",
              "schema",
              "domain",
              "module",
              "example",
              "policy",
              "pattern"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.).+"
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "stability": {
            "type": "string",
            "enum": [
              "stable",
              "experimental",
              "deprecated"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
