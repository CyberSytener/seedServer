{
  "catalog_version": "v0",
  "module_id": "admin_remove_product",
  "title": "Admin Remove Product",
  "description": "Deactivate a product in the catalog.",
  "input_schema": {
    "type": "object",
    "properties": {
      "item_id": {
        "type": "string"
      },
      "sku": {
        "type": "string"
      },
      "reason": {
        "type": "string"
      }
    },
    "required": [
      "item_id"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
