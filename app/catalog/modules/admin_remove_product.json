    "DRY_RUN"
  ],
  "idempotent": false,
  "timeout_sec": 20,
  "retry_policy": {
    "max_retries": 0,
    "strategy": "exponential_backoff_jitter",
    "backoff_ms": [
      200,
      800
    ]
  },
  "cost_profile": {
    "tier": "low",
    "estimated_units_per_call": 1,
    "notes": "heuristic_estimate_v0"
  },
