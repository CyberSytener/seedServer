{
  "catalog_version": "v0",
  "module_id": "hot_offer_generator",
  "title": "Hot Offer Generator",
  "description": "Generate a hot offer from priority inventory and sales stats.",
  "input_schema": {
    "type": "object",
    "properties": {
      "priority_items": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "sales_stats": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "currency": {
        "type": "string"
      },
      "margin_pct": {
        "type": "number"
      },
      "waste_overhead": {
        "type": "number"
      },
      "mock_offer": {
        "type": "object"
      }
    },
    "required": [
      "priority_items"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "offer": {
        "type": "object"
      },
      "offer_id": {
        "type": "string"
      }
    },
    "required": [
      "offer",
      "offer_id"
    ]
  },
  "side_effects": [
    "llm.call:offer_generation"
  ],
  "required_scopes": [
    "runs:write"
  ],
  "stability": "stable",
  "examples": [
    {
      "title": "minimal_call",
      "input": {
        "priority_items": []
      }
    },
    {
      "title": "mapped_call",
      "input": {
        "priority_items": {
          "from": "payload.priority_items"
        }
      }
    }
  ],
  "tags": [
    "hot_offer",
    "neoeats",
    "saga"
  ],
  "run_modes_supported": [
    "LIVE",
    "DRY_RUN",
    "STUB"
  ],
  "idempotent": true,
  "timeout_sec": 40,
  "retry_policy": {
    "max_retries": 1,
    "strategy": "exponential_backoff_jitter",
    "backoff_ms": [
      200,
      800
    ]
  },
  "cost_profile": {
    "tier": "high",
    "estimated_units_per_call": 4,
    "notes": "heuristic_estimate_v0"
  },
  "risk_level": "medium",
  "depends_on": [
    "llm_provider",
    "sales_stats_fetch"
  ],
  "produces": [
    "offer",
    "offer_id"
  ]
}
